{
  "expo": {
    "name": "BillSplit",
    "slug": "billsplit-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ayush.billsplit",
      "infoPlist": {
        "NSCameraUsageDescription": "BillSplit uses your camera to scan receipts and auto-fill expense details.",
        "NSPhotoLibraryUsageDescription": "BillSplit uses your photo library to attach receipt images to expenses."
      }
    },
    "android": {
      "package": "com.ayush.billsplit",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "BillSplit uses your camera to scan receipts."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "55dec4a1-b9a3-4846-9e8e-6d7e5072781c"
      }
    }
  }
}
